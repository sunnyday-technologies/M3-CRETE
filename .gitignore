# Intermediate Fusion exports (superseded by M3-2_Assembly_user.step)
CAD/M3-2_Assembly_user_cor.step
CAD/M3-2_Assembly_userY.step
CAD/M3-2_Assembly_userYY.step

# NOTE: CAD/M3-2_Assembly_user.step IS tracked — it is Nick's Fusion-placed
