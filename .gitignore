# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# Claude Code config (local-only)
.claude/

# Session notes / internal context (never publish)
conversation-summary.md

# Python virtual environments
cad_venv/
.venv/
__pycache__/

# NemoCrete — proprietary pump system (separate project)
NEMA_CRETE/

# Build artifacts
build/
*.o
*.elf
*.hex
*.bin

# PlatformIO (if used for firmware)
.pio/
.pioenvs/
.piolibdeps/

# Node modules (if configurator uses npm)
node_modules/

# Temporary files
*.tmp
*.log
*.bak
~*

# Generated assembly preview (rebuild with: cad_venv/Scripts/python CAD/preview_assembly.py)
CAD/_preview/

# Numbered assembly snapshots (experimental exports, keep local only)
CAD/M3-2_Assembly[0-9]*.step

# Custom per-build CAD (user-local work)
CAD/Custom/*.step
CAD/Custom/*.stl

# Dev/test STEP files (not for GitHub)
CAD/box_test.step
CAD/corner_test.step
CAD/rotation_test.step

# Dev probe/test scripts (kept locally, not essential for repo)
CAD/box_test.py
CAD/corner_test.py
CAD/rotation_test.py
CAD/read_adjusted.py
CAD/read_v3.py
CAD/probe_actuator.py
CAD/probe_brackets.py
CAD/probe_plates.py
CAD/extract_carriage.py
CAD/diff_user_edit.py

# Local CAD working copies — authoritative output is CAD/M3-2_Assembly.step
# Everything under CAD/M3-2_* is local-only by default; the single tracked
# file is CAD/M3-2_Assembly.step via the negation below.
CAD/M3-2_Assembly_v2.step
CAD/M3-2_Assembly_lite.step
CAD/M3-2_Assembly_v20.step
CAD/M3-2_AllC.step
CAD/M3-2_Assembly_user.step
CAD/M3-2_Assembly_user.f3d
CAD/M3-2_Assembly_new.f3d
CAD/M3-2_Assembly_*.step
!CAD/M3-2_Assembly.step
CAD/M3-2_As*.step
CAD/M3-2_Ass*.step
CAD/M3-2_Az*.step
CAD/test_*.step

# NOTE: CAD/M3-2_Assembly.step IS tracked — the published assembly for
# Hackaday.io / download. Rebuild with: cad_venv/Scripts/python CAD/m3_2_assembly.py

