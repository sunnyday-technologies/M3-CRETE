*.tmp
*.log
*.bak
~*

# Generated assembly preview (rebuild with: cad_venv/Scripts/python CAD/preview_assembly.py)
CAD/_preview/

# Numbered assembly snapshots (experimental exports, keep local only)
CAD/M3-2_Assembly[0-9]*.step

# Custom per-build CAD (user-local work)
CAD/Custom/*.step
CAD/Custom/*.stl

# Dev/test STEP files (not for GitHub)
CAD/box_test.step
CAD/corner_test.step
CAD/rotation_test.step

